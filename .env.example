# Copy this file to .env and fill in your credentials
UTILITY_USERNAME=email@gmail.com
UTILITY_PASSWORD=your_password_here

# Account details
SERVICE_LOCATION_NUMBER=your_service_location_number
ACCOUNT_NUMBER=your_account_number

# Live pytest also accepts these aliases:
# HSV_UTIL_USERNAME=email@gmail.com
# HSV_UTIL_PASSWORD=your_password_here
# HSV_UTIL_SERVICE_LOCATION=your_service_location_number
# HSV_UTIL_ACCOUNT_NUMBER=your_account_number
